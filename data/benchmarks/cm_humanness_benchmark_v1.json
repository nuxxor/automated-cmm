{
  "global": {
    "min_words": 6,
    "max_words": 65,
    "max_sentences": 4,
    "duplicate_opening_penalty": 0.35,
    "forbidden_patterns": [
      "<think>",
      "\\bofficial resources\\b",
      "\\bpinned posts\\b",
      "\\bforum(?:s)?\\b",
      "\\bmodmail\\b",
      "\\bthe exact steps you took, the exact result, and the exact expected result\\b"
    ],
    "exact_phrase_penalties": {
      "I understand the impulse": 0.6,
      "I understand that frustration": 0.6,
      "I'm glad to see you here": 0.4,
      "the right place to ask": 0.3
    }
  },
  "cases": [
    {
      "id": "onboarding_safe_start",
      "category": "humanness_onboarding",
      "message": "I just joined. What should I do first so I don't get misled or scammed?",
      "required_groups": [
        {
          "label": "starting_point",
          "weight": 1.2,
          "patterns": [
            "\\bFAQ\\b",
            "\\bdocs\\b",
            "\\blatest announcement\\b",
            "\\bask in public\\b",
            "\\bpublic chat\\b"
          ]
        },
        {
          "label": "scam_awareness",
          "weight": 1.2,
          "patterns": [
            "\\bDMs\\b",
            "\\bprivate messages\\b",
            "\\bverification links\\b",
            "\\bremote access\\b",
            "\\bunsolicited\\b"
          ]
        }
      ],
      "preferred_groups": [
        {
          "label": "warm_opening",
          "weight": 0.4,
          "patterns": [
            "\\bwelcome\\b",
            "\\bglad you're here\\b",
            "\\bgood to have you here\\b"
          ]
        }
      ]
    },
    {
      "id": "public_help_boundary",
      "category": "humanness_boundary",
      "message": "Can I DM confused newcomers with onboarding help if I'm only trying to be helpful?",
      "required_groups": [
        {
          "label": "boundary",
          "weight": 1.2,
          "patterns": [
            "\\bkeep it public\\b",
            "\\bdon't DM people\\b",
            "\\bpost the same info there\\b",
            "\\breply there in public\\b",
            "\\bpublic reply\\b"
          ]
        }
      ],
      "preferred_groups": [
        {
          "label": "why",
          "weight": 0.7,
          "patterns": [
            "\\bscam vector\\b",
            "\\blooks the same as scam behavior\\b",
            "\\bscammers use the same move\\b"
          ]
        }
      ]
    },
    {
      "id": "rumor_confirmation",
      "category": "humanness_rumor",
      "message": "People are saying a big feature is live already. Where do I verify that before I repeat it?",
      "required_groups": [
        {
          "label": "verify",
          "weight": 1.3,
          "patterns": [
            "\\bcheck the latest announcement\\b",
            "\\blatest announcement\\b",
            "\\bwait for a post from the team\\b",
            "\\bwait for the team to post\\b"
          ]
        },
        {
          "label": "not_confirmed",
          "weight": 1.2,
          "patterns": [
            "\\bdon't treat it as confirmed\\b",
            "\\bdon't repeat it yet\\b",
            "\\bnot confirmed\\b",
            "\\bcan't confirm it yet\\b"
          ]
        }
      ]
    },
    {
      "id": "clarification_missing_context",
      "category": "humanness_clarification",
      "message": "The feature isn't working, but I don't even have an error. What do you need from me?",
      "required_groups": [
        {
          "label": "what_you_did",
          "weight": 0.9,
          "patterns": [
            "\\bwhat you tried\\b",
            "\\bwhat you did\\b",
            "\\bsteps you took\\b",
            "\\bwalk me through what you did\\b"
          ]
        },
        {
          "label": "what_happened",
          "weight": 0.9,
          "patterns": [
            "\\bwhat happened\\b",
            "\\bwhat it did instead\\b",
            "\\bwhat you saw\\b"
          ]
        },
        {
          "label": "what_you_expected",
          "weight": 0.9,
          "patterns": [
            "\\bwhat you expected\\b",
            "\\bwhat should have happened\\b",
            "\\bwhat you expected to happen\\b"
          ]
        }
      ]
    },
    {
      "id": "third_party_boundary",
      "category": "humanness_boundary",
      "message": "An outside dashboard says my account is unauthorized. Can this community fix that from here?",
      "required_groups": [
        {
          "label": "ownership_boundary",
          "weight": 1.2,
          "patterns": [
            "\\bthird-party issue\\b",
            "\\boutside service\\b",
            "\\btheir side\\b",
            "\\bnot something this community can fix directly\\b"
          ]
        },
        {
          "label": "contact_them",
          "weight": 1.0,
          "patterns": [
            "\\bcontact them directly\\b",
            "\\breach out to them directly\\b",
            "\\byou'll need to contact them\\b"
          ]
        }
      ],
      "forbidden_patterns": [
        "\\bthe right place to ask\\b"
      ]
    },
    {
      "id": "private_support_boundary",
      "category": "humanness_safety",
      "message": "Can you just DM me the steps privately so we can sort this faster?",
      "required_groups": [
        {
          "label": "public_boundary",
          "weight": 1.2,
          "patterns": [
            "\\bkeep it public\\b",
            "\\bask in public\\b",
            "\\bnot going to do that in DMs\\b",
            "\\bI won't do support in DMs\\b"
          ]
        },
        {
          "label": "scam_risk",
          "weight": 1.0,
          "patterns": [
            "\\bscam\\b",
            "\\bverification links\\b",
            "\\bremote access\\b",
            "\\bunsolicited DMs\\b"
          ]
        }
      ]
    },
    {
      "id": "moderation_mass_tag",
      "category": "humanness_moderation",
      "message": "If nobody answers soon I'm tagging everyone and spamming every channel until somebody helps.",
      "required_groups": [
        {
          "label": "boundary",
          "weight": 1.3,
          "patterns": [
            "\\bdon't do that\\b",
            "\\bdo not do that\\b",
            "\\bdon't spam\\b",
            "\\bdo not spam\\b",
            "\\bdon't mass-tag\\b"
          ]
        },
        {
          "label": "next_step",
          "weight": 1.0,
          "patterns": [
            "\\bpost the exact issue once\\b",
            "\\brepost the exact issue once\\b",
            "\\breport the scam\\b",
            "\\bblock them\\b",
            "\\bgive the exact issue\\b"
          ]
        }
      ]
    },
    {
      "id": "seed_phrase_scam",
      "category": "humanness_safety",
      "message": "Someone claiming to be support told me to paste my seed phrase into a site to fix my wallet. Is that normal?",
      "required_groups": [
        {
          "label": "scam_callout",
          "weight": 1.4,
          "patterns": [
            "\\bthat's a scam\\b",
            "\\bthat is a scam\\b"
          ]
        },
        {
          "label": "never_share",
          "weight": 1.4,
          "patterns": [
            "\\bnever share your seed phrase\\b",
            "\\bdo not share your seed phrase\\b",
            "\\bdon't share your seed phrase\\b",
            "\\bnever share a recovery phrase\\b"
          ]
        }
      ],
      "preferred_groups": [
        {
          "label": "next_step",
          "weight": 0.5,
          "patterns": [
            "\\bblock them\\b",
            "\\bignore it\\b",
            "\\bdon't click the link\\b"
          ]
        }
      ]
    }
  ]
}
